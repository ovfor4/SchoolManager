{
  "openapi": "3.0.3",
  "info": {
    "title": "SchoolManager API",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "summary": "Backend health check",
        "responses": {
          "200": {
            "description": "Service is healthy"
          }
        }
      }
    },
    "/api/students": {
      "get": {
        "summary": "List students from school_index.db only",
        "responses": {
          "200": {
            "description": "Student list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "students": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Student"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a student folder and per-student data.db",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "display_name": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Student created"
          }
        }
      }
    },
    "/api/students/{studentId}": {
      "get": {
        "summary": "Get one student with info fields and grades",
        "parameters": [
          {
            "$ref": "#/components/parameters/StudentId"
          }
        ],
        "responses": {
          "200": {
            "description": "Student detail"
          },
          "404": {
            "description": "Student not found"
          }
        }
      },
      "patch": {
        "summary": "Patch student metadata",
        "parameters": [
          {
            "$ref": "#/components/parameters/StudentId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StudentInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Student patched"
          },
          "404": {
            "description": "Student not found"
          }
        }
      },
      "delete": {
        "summary": "Delete a student and that student's folder",
        "parameters": [
          {
            "$ref": "#/components/parameters/StudentId"
          }
        ],
        "responses": {
          "200": {
            "description": "Student deleted"
          },
          "404": {
            "description": "Student not found"
          }
        }
      }
    },
    "/api/students/{studentId}/grades": {
      "get": {
        "summary": "List generic grade records for one student",
        "parameters": [
          {
            "$ref": "#/components/parameters/StudentId"
          }
        ],
        "responses": {
          "200": {
            "description": "Grade list"
          }
        }
      },
      "post": {
        "summary": "Create a generic grade record",
        "parameters": [
          {
            "$ref": "#/components/parameters/StudentId"
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GradeInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Grade created"
          }
        }
      }
    },
    "/api/students/{studentId}/grades/{gradeId}": {
      "patch": {
        "summary": "Patch only changed grade fields",
        "parameters": [
          {
            "$ref": "#/components/parameters/StudentId"
          },
          {
            "$ref": "#/components/parameters/GradeId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GradeInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Grade patched and broadcast over websocket"
          },
          "404": {
            "description": "Student or grade not found"
          }
        }
      },
      "delete": {
        "summary": "Delete a grade record",
        "parameters": [
          {
            "$ref": "#/components/parameters/StudentId"
          },
          {
            "$ref": "#/components/parameters/GradeId"
          }
        ],
        "responses": {
          "200": {
            "description": "Grade deleted"
          }
        }
      }
    },
    "/api/file-manager/contexts/{contextType}/{contextId}/entries": {
      "get": {
        "summary": "List active file manager entries for a context and parent folder",
        "parameters": [
          {
            "$ref": "#/components/parameters/ContextType"
          },
          {
            "$ref": "#/components/parameters/ContextId"
          },
          {
            "name": "parent_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File entry list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "entries": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/FileEntry"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/file-manager/contexts/{contextType}/{contextId}/files": {
      "post": {
        "summary": "Upload a file with tmp, DB pending, atomic rename, DB active flow",
        "parameters": [
          {
            "$ref": "#/components/parameters/ContextType"
          },
          {
            "$ref": "#/components/parameters/ContextId"
          },
          {
            "name": "parent_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                },
                "required": [
                  "file"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "File uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "entry": {
                      "$ref": "#/components/schemas/FileEntry"
                    }
                  }
                }
              }
            }
          },
          "413": {
            "description": "File exceeds configured upload size limit"
          },
          "409": {
            "description": "Sibling name conflict"
          }
        }
      }
    },
    "/api/file-manager/contexts/{contextType}/{contextId}/folders": {
      "post": {
        "summary": "Create a logical folder in a file manager context",
        "parameters": [
          {
            "$ref": "#/components/parameters/ContextType"
          },
          {
            "$ref": "#/components/parameters/ContextId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name"
                ],
                "properties": {
                  "parent_id": {
                    "type": "string",
                    "nullable": true
                  },
                  "name": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Folder created"
          },
          "409": {
            "description": "Sibling name conflict"
          }
        }
      }
    },
    "/api/file-manager/contexts/{contextType}/{contextId}/entries/{entryId}": {
      "patch": {
        "summary": "Rename an active file or folder",
        "parameters": [
          {
            "$ref": "#/components/parameters/ContextType"
          },
          {
            "$ref": "#/components/parameters/ContextId"
          },
          {
            "$ref": "#/components/parameters/EntryId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Entry renamed"
          },
          "404": {
            "description": "Entry not found"
          },
          "409": {
            "description": "Sibling name conflict"
          }
        }
      },
      "delete": {
        "summary": "Move an active file or folder subtree to trash",
        "parameters": [
          {
            "$ref": "#/components/parameters/ContextType"
          },
          {
            "$ref": "#/components/parameters/ContextId"
          },
          {
            "$ref": "#/components/parameters/EntryId"
          }
        ],
        "responses": {
          "200": {
            "description": "Entry moved to trash"
          },
          "404": {
            "description": "Entry not found"
          }
        }
      }
    },
    "/api/file-manager/contexts/{contextType}/{contextId}/entries/{entryId}/download": {
      "get": {
        "summary": "Download an active uploaded file",
        "parameters": [
          {
            "$ref": "#/components/parameters/ContextType"
          },
          {
            "$ref": "#/components/parameters/ContextId"
          },
          {
            "$ref": "#/components/parameters/EntryId"
          }
        ],
        "responses": {
          "200": {
            "description": "File bytes"
          },
          "404": {
            "description": "File not found"
          }
        }
      }
    },
    "/api/file-manager/contexts/{contextType}/{contextId}/trash": {
      "get": {
        "summary": "List trash entries for a file manager context",
        "parameters": [
          {
            "$ref": "#/components/parameters/ContextType"
          },
          {
            "$ref": "#/components/parameters/ContextId"
          }
        ],
        "responses": {
          "200": {
            "description": "Trash entry list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "trash": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/TrashEntry"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/file-manager/contexts/{contextType}/{contextId}/trash/{trashEntryId}/restore": {
      "post": {
        "summary": "Restore a trash entry to its original parent",
        "parameters": [
          {
            "$ref": "#/components/parameters/ContextType"
          },
          {
            "$ref": "#/components/parameters/ContextId"
          },
          {
            "$ref": "#/components/parameters/TrashEntryId"
          }
        ],
        "responses": {
          "200": {
            "description": "Trash entry restored"
          },
          "409": {
            "description": "Original parent missing or sibling name conflict"
          }
        }
      }
    },
    "/api/file-manager/contexts/{contextType}/{contextId}/trash/{trashEntryId}": {
      "delete": {
        "summary": "Permanently delete a trash entry and its stored content",
        "parameters": [
          {
            "$ref": "#/components/parameters/ContextType"
          },
          {
            "$ref": "#/components/parameters/ContextId"
          },
          {
            "$ref": "#/components/parameters/TrashEntryId"
          }
        ],
        "responses": {
          "200": {
            "description": "Trash entry permanently deleted"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "StudentId": {
        "name": "studentId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "GradeId": {
        "name": "gradeId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "ContextType": {
        "name": "contextType",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "enum": [
            "student_uploads"
          ]
        }
      },
      "ContextId": {
        "name": "contextId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "EntryId": {
        "name": "entryId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "TrashEntryId": {
        "name": "trashEntryId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "Student": {
        "type": "object",
        "required": [
          "id",
          "display_name",
          "folder_path",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "folder_path": {
            "type": "string"
          },
          "created_at": {
            "type": "integer",
            "format": "int64"
          },
          "updated_at": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "Grade": {
        "type": "object",
        "required": [
          "id",
          "title",
          "score",
          "max_score",
          "occurred_on",
          "notes",
          "updated_at"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "score": {
            "type": "string"
          },
          "max_score": {
            "type": "string"
          },
          "occurred_on": {
            "type": "string",
            "format": "date"
          },
          "notes": {
            "type": "string"
          },
          "updated_at": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "StudentInput": {
        "type": "object",
        "required": [
          "display_name"
        ],
        "properties": {
          "display_name": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "GradeInput": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "score": {
            "type": "string"
          },
          "max_score": {
            "type": "string"
          },
          "occurred_on": {
            "type": "string",
            "format": "date"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "FileEntry": {
        "type": "object",
        "required": [
          "id",
          "context_type",
          "context_id",
          "parent_id",
          "kind",
          "name",
          "mime_type",
          "size_bytes",
          "status",
          "created_at",
          "updated_at",
          "trashed_at"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "context_type": {
            "type": "string"
          },
          "context_id": {
            "type": "string"
          },
          "parent_id": {
            "type": "string",
            "nullable": true
          },
          "kind": {
            "type": "string",
            "enum": [
              "file",
              "folder"
            ]
          },
          "name": {
            "type": "string"
          },
          "mime_type": {
            "type": "string"
          },
          "size_bytes": {
            "type": "integer",
            "format": "int64"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "active",
              "trashed"
            ]
          },
          "created_at": {
            "type": "integer",
            "format": "int64"
          },
          "updated_at": {
            "type": "integer",
            "format": "int64"
          },
          "trashed_at": {
            "type": "integer",
            "format": "int64",
            "nullable": true
          }
        }
      },
      "TrashEntry": {
        "type": "object",
        "required": [
          "id",
          "context_type",
          "context_id",
          "root_entry_id",
          "original_parent_id",
          "root_name",
          "root_kind",
          "item_count",
          "trashed_at"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "context_type": {
            "type": "string"
          },
          "context_id": {
            "type": "string"
          },
          "root_entry_id": {
            "type": "string"
          },
          "original_parent_id": {
            "type": "string",
            "nullable": true
          },
          "root_name": {
            "type": "string"
          },
          "root_kind": {
            "type": "string",
            "enum": [
              "file",
              "folder"
            ]
          },
          "item_count": {
            "type": "integer",
            "format": "int64"
          },
          "trashed_at": {
            "type": "integer",
            "format": "int64"
          }
        }
      }
    }
  }
}
